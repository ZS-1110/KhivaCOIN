# KhivaCoin Airdrop Server — .env fayli
# Bu faylni hech kimga ko'rsatmang!

# Airdrop tokenlar turadigan hamyonning PRIVATE KEY (Base58 format)
# Phantom: Settings > Security & Privacy > Export Private Key
# Solflare: Settings > Export Private Key
SENDER_PRIVATE_KEY=bu_yerga_private_keyingizni_kiriting

# KIC Token contract manzili (to'liq manzil)
TOKEN_MINT=8qSBA3eoypLJXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Solana RPC (bepul yoki premium)
# Bepul: https://api.mainnet-beta.solana.com
# Premium (tezroq): https://rpc.helius.xyz/?api-key=YOUR_KEY
RPC_URL=https://api.mainnet-beta.solana.com

# Server porti
PORT=3001
